{
  "name": "@astra-spec/astra-theme",
  "version": "0.0.1",
  "description": "A rich MyST web theme for ASTRA analyses — the presentation half of the @astra-spec/mystra pair. Extends @myst-theme/book.",
  "license": "BSD-3-Clause",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prod:copy": "cp remix.config.prod.js remix.config.js",
    "dev:copy": "cp remix.config.dev.js remix.config.js",
    "build:css": "tailwindcss -m -i ./styles/app.css -o app/styles/app.css",
    "build:thebe": "copy-thebe-assets ./public",
    "build": "npm run prod:copy && npm run build:thebe && npm run build:css && remix build",
    "dev": "npm run dev:copy && npm run build:thebe && npm run build:css && remix dev",
    "start": "node ./server.js",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf public/build build app/styles/app.css remix.config.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@astra-spec/store-types": "*",
    "@floating-ui/react": "^0.27.0",
    "@heroicons/react": "^2.0.18",
    "@myst-theme/anywidget": "^1.3.1",
    "@myst-theme/common": "^1.3.1",
    "@myst-theme/frontmatter": "^1.3.1",
    "@myst-theme/icons": "^1.3.1",
    "@myst-theme/jupyter": "^1.3.1",
    "@myst-theme/landing-pages": "^1.3.1",
    "@myst-theme/providers": "^1.3.1",
    "@myst-theme/search": "^1.3.1",
    "@myst-theme/search-minisearch": "^1.3.1",
    "@myst-theme/site": "^1.3.1",
    "@myst-theme/styles": "^1.3.1",
    "@remix-run/express": "~1.17.0",
    "@remix-run/node": "~1.17.0",
    "@remix-run/react": "~1.17.0",
    "classnames": "^2.3.2",
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "get-port": "^5.1.1",
    "morgan": "^1.10.0",
    "myst-common": "^1.8.1",
    "myst-config": "^1.8.1",
    "myst-migrate": "^1.7.1",
    "myst-spec-ext": "^1.8.1",
    "myst-to-react": "^1.3.1",
    "node-fetch": "^2.6.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "thebe-core": "^0.5.0"
  },
  "devDependencies": {
    "@remix-run/dev": "~1.17.0",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node-fetch": "^2.6.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "comments": {
    "overrides": "Force a single React 19 across the whole tree — jupyterlab/thebe deps pull React 18, which would bundle multiple React copies into the server build and break SSR hooks. Mirrors @myst-theme upstream."
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
